TOPIC: PROVISIONERS
========================

3 types of PROVISIONERS are 1. local-exec   2. remote-exec   3. file-exec

lets do it practically


[root@TERRAFORM ~]# cat main.tf 

resource "aws_instance" "myinstance" {
tags = {
Name = "My-Server"
}
ami = "ami-098e39bafa7e7303d"
instance_type = var.itype
count = 1

provisioner "local-exec" {
  command = "echo 'Instance created with id: ${aws_instance.id}' >> server-id.txt"
}
}

variable "itype" {
type = string
default = "t3.micro"
}
:wq

the above file is for local-exec provisioners

