for that we will use alias concept here




[root@TERRAFORM ~]# vim main.tf
[root@TERRAFORM ~]# cat main.tf
provider "aws" {
  region = "us-east-1"
}

provider "aws" {
  region = "ap-south-1"
}


[root@TERRAFORM ~]# vim main.tf
[root@TERRAFORM ~]# cat main.tf
provider "aws" {
  region = "us-east-1"
  alias = "usa"
}

provider "aws" {
  region = "ap-south-1"
  alias = "mumbai"
}


resource "aws_instance" "devops" {
  tags = {
    Name = "NV-Instance"
    provider = "aws.usa"
  }

  ami                    = "ami-id-in-usa"
  instance_type          = "t3.micro"
  key_name               = "Anjeneyakeypair"
  availability_zone      = "us-east-1a"
  root_block_device {
    volume_size = 10
  }
}


resource "aws_instance" "devops" {
  tags = {
    Name = "Mumbai-Instance"
  }
  provider = "aws.mumbai"

  ami                    = "ami-id-mumbai"
  instance_type          = "t3.micro"
  availability_zone      = "ap-south-1a"
  root_block_device {
    volume_size = 10
  }
}
